{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "Adds a procedurally generated dungeon to Minecraft with many different themes and loot/difficulty tiers.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/ProceduralDungeon",
		"sources": "https://github.com/brainage04/ProceduralDungeon"
	},
	"license": "MIT",
	"icon": "assets/procedural_dungeon/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.github.brainage04.procedural_dungeon.ProceduralDungeon"
		],
		"fabric-datagen": [
			"com.github.brainage04.procedural_dungeon.datagen.ModDataGenerator"
		],
		"fabric-gametest": [
			"com.github.brainage04.procedural_dungeon.test.DungeonVariantGameTests"
		]
	},
	"mixins": [
		"procedural_dungeon.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"accessWidener": "procedural_dungeon.accesswidener"
}
